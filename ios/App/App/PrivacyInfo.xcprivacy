<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ───────────────────────────────────────────────────────────
         Pixel Terrarium privacy manifest.
         The app runs entirely on-device. No telemetry, no analytics,
         no IAP, no ads, no network calls. The only "data" persisted
         is the user's saved custom elements/creatures and UI
         preferences via localStorage / UserDefaults inside WKWebView.
         ─────────────────────────────────────────────────────────── -->

    <!-- We do not track users across apps or websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains contacted. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- We do not collect any user-identifying data. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required-reason API declarations for system APIs that the
         Capacitor WebView (WKWebView) may invoke under the hood.
         Reason codes from:
         https://developer.apple.com/documentation/bundleresources/privacy_manifest_files/describing_use_of_required_reason_api -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults — Capacitor uses this for plugin storage and
             we use it for theme + saved element/creature persistence. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamp — WKWebView caches web assets, which
             internally reads file modification dates. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>

        <!-- System boot time — WKWebView / WebKit calls this for
             monotonic timing references during JS execution. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string>
            </array>
        </dict>

        <!-- Disk space — WebKit checks available storage before
             allowing localStorage / IndexedDB writes. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>E174.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
